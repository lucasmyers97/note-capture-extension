{
  "description": "Add-on to capture highlights as notes in your file system",
  "manifest_version": 3,
  "name": "Org capture",
  "version": "0.1.0",
  "icons": {
    "48": "icons/message.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "note_capture@lucasmyers97.github.io",
      "strict_min_version": "50.0"
    }
  },

  "background": {
    "scripts": ["background.js"],
    "type": "module"
  },

  "action": {
    "default_icon": "icons/message.svg"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "commands": {
    "save-highlight": {
      "suggested_key": {
        "default": "Alt+Shift+N"
      },
      "description": "Save highlighted text in file"
    },
    "open-menu": {
      "suggested_key": {
        "default": "Alt+Shift+M"
      },
      "description": "Open options menu"
    }
  },

  "permissions": ["nativeMessaging", "menus", "storage", "tabs", "notifications", "activeTab", "scripting"]
}
