{
  "description": "Native messaging example add-on",
  "manifest_version": 2,
  "name": "Native messaging example",
  "version": "1.0",
  "icons": {
    "48": "icons/message.svg"
  },

  "browser_specific_settings": {
    "gecko": {
      "id": "org_capture@example.org",
      "strict_min_version": "50.0"
    }
  },

  "background": {
    "scripts": ["background.js"]
  },

  "browser_action": {
    "default_icon": "icons/message.svg",
    "default_popup": "prompt.html"
  },

  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },

  "permissions": ["nativeMessaging", "menus", "storage", "tabs"]
}
